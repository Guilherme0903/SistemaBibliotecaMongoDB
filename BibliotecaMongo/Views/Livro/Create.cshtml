@model BibliotecaMongo.Models.Livro

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">

            <h3 class="mb-4">+ Cadastrar Livro</h3>

            <form asp-action="Create" method="post">

                <div class="mb-3">
                    <label class="form-label">Título</label>
                    <input asp-for="Titulo" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Autor</label>
                    <input asp-for="Autor" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Ano</label>
                    <input asp-for="Ano" type="number" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Gênero</label>
                    <input asp-for="Genero" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Exemplares</label>
                    <input asp-for="Exemplares" type="number" class="form-control" />
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
                    <button type="submit" class="btn btn-success">Salvar</button>
                </div>

            </form>

        </div>
    </div>
</div>