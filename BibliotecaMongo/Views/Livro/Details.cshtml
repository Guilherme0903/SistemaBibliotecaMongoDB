@model BibliotecaMongo.Models.Livro

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">

            <h3 class="mb-4"> Detalhes do Livro</h3>

            <div class="mb-3">
                <strong>Título:</strong>
                <p class="mb-1">@Model.Titulo</p>
            </div>

            <div class="mb-3">
                <strong>Autor:</strong>
                <p class="mb-1">@Model.Autor</p>
            </div>

            <div class="mb-3">
                <strong>Ano:</strong>
                <p class="mb-1">@Model.Ano</p>
            </div>

            <div class="mb-3">
                <strong>Gênero:</strong>
                <p class="mb-1">@Model.Genero</p>
            </div>

            <div class="mb-3">
                <strong>Exemplares:</strong><br />

                @if (Model.Exemplares > 0)
                {
                    <span class="badge bg-success">@Model.Exemplares disponíveis</span>
                }
                else
                {
                    <span class="badge bg-danger">Indisponível</span>
                }
            </div>

            <hr />

            <h5 class="mb-3">📌 Empréstimos</h5>

            @if (Model.Emprestimos != null && Model.Emprestimos.Count > 0)
            {
                <ul class="list-group mb-3">
                    @foreach (var e in Model.Emprestimos)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @e

                            <form asp-action="Devolver" method="post" style="margin:0;">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="nomePessoa" value="@e" />
                                <button class="btn btn-sm btn-outline-danger">Devolver</button>
                            </form>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">Nenhum empréstimo registrado</p>
            }

            <form asp-action="Emprestar" method="post" class="mt-3">
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="input-group">
                    <input type="text" name="nomePessoa" class="form-control" placeholder="Nome da pessoa" required />

                    @if (Model.Exemplares > 0)
                    {
                        <button type="submit" class="btn btn-success">Emprestar</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-secondary" disabled>Sem estoque</button>
                    }
                </div>
            </form>

            <hr />

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">Voltar</a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
            </div>

        </div>
    </div>
</div>