@model List<BibliotecaMongo.Models.Livro>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2> Biblioteca MongoDB</h2>
        <a asp-action="Create" class="btn btn-success">+ Novo Livro</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Título</th>
                        <th>Autor</th>
                        <th>Ano</th>
                        <th>Gênero</th>
                        <th>Exemplares</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var livro in Model)
                    {
                        <tr>
                            <td><strong>@livro.Titulo</strong></td>
                            <td>@livro.Autor</td>
                            <td>@livro.Ano</td>
                            <td>@livro.Genero</td>
                            <td>
                                @if (livro.Exemplares > 0)
                                {
                                    <span class="badge bg-success">@livro.Exemplares disponíveis</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Indisponível</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@livro.Id"
                                   class="btn btn-sm btn-outline-primary">Detalhes</a>
                                <a asp-action="Edit" asp-route-id="@livro.Id"
                                   class="btn btn-sm btn-outline-warning">Editar</a>
                                <a asp-action="Delete" asp-route-id="@livro.Id"
                                   class="btn btn-sm btn-outline-danger">Excluir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>